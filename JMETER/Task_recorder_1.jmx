              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">int count = vars.get(&quot;P_ID_matchNr&quot;) as int
StringBuilder sb = new StringBuilder()

def boundary = vars.get(&quot;WEBKITBOUNDARY&quot;)

for (int i = 1; i &lt;= count; i++) {
    def id = vars.get(&quot;P_ID_&quot; + i)
    def price = vars.get(&quot;P_PRICE_&quot; + i)

    sb.append(&quot;----WebKitFormBoundary&quot;).append(boundary).append(&quot;\r\n&quot;)
    sb.append(&quot;Content-Disposition: form-data; name=\&quot;product_price_${id}\&quot;\r\n\r\n&quot;)
    sb.append(price).append(&quot;\r\n&quot;)
}

vars.put(&quot;PRODUCT_PRICES&quot;, sb.toString())
</stringProp>
              </JSR223PreProcessor>
