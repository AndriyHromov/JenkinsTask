pipeline {
    agent any

    stages {
        stage('Run JMeter Test') {
            steps {
                bat """
                @echo off
                set JMETER_HOME=C:\\JMETER\\apache-jmeter-5.6.3
                set PATH=%JMETER_HOME%\\bin;%PATH%
                
                if exist results rmdir /s /q results
                mkdir results

                call jmeter.bat -n ^
                -t "%WORKSPACE%\\Task_recorder_1.jmx" ^
                -l results\\result.jtl ^
                -e -o results\\report
                """
            }
        }
    }
    
    post {
        always {
            
            archiveArtifacts artifacts: 'results/report/index.html, results/result.jtl', fingerprint: true

        
            publishHTML(target: [
                reportDir: 'results/report',
                reportFiles: 'index.html',
                reportName: 'JMeter Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: true
            ])
        }
    }
}
